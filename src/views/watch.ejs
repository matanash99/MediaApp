<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Watching <%= video.title %> - KVALIM</title>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#141414">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="icon" type="image/png" href="/icon_192.png">
    <link rel="apple-touch-icon" href="/icon_192.png">    


    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(reg => console.log('Service worker registered!', reg))
                    .catch(err => console.log('Service worker failed!', err));
            });
        }
    </script>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* OVERRIDE the global login flexbox */
        body { margin: 0; background-color: #141414; color: #e0e0e0; display: block; height: auto; }
        
        /* Navbar (Perfectly matched to Gallery) */
        .navbar { display: flex; justify-content: space-between; padding: 1.5rem 4%; background: #000; width: 100%; box-sizing: border-box; }
        .navbar h2 { margin: 0; color: #e50914; font-size: 1.8rem; }
        .nav-links { display: flex; align-items: center; }
        .nav-links a { color: white; text-decoration: none; margin-left: 1.5rem; font-weight: bold; }

        /* Player Layout */
        .player-container { max-width: 1200px; margin: 2rem auto; padding: 0 4%; }
        .back-btn { display: inline-block; margin-bottom: 1.5rem; color: #aaa; text-decoration: none; font-size: 1.1rem; transition: color 0.2s; }
        .back-btn:hover { color: #fff; }

        /* 16:9 Aspect Ratio Video Wrapper */
        .video-wrapper { position: relative; padding-bottom: 56.25%; height: 0; background: #000; border-radius: 8px; overflow: hidden; box-shadow: 0 8px 25px rgba(0,0,0,0.6); }
        video { position: absolute; top: 0; left: 0; width: 100%; height: 100%; outline: none; }

        /* Video Meta Info */
        .video-info { margin-top: 2rem; background: #1e1e1e; padding: 2rem; border-radius: 8px; }
        .video-title { font-size: 2rem; margin: 0 0 0.5rem 0; color: #fff; }
        .series-context { font-size: 1.2rem; color: #4a90e2; margin-top: 0; margin-bottom: 1rem; }
        .upload-date { font-size: 0.9rem; color: #666; }

        /* Download Button Styles */
        .download-section { margin-top: 2rem; padding: 1.5rem; background: #1a1a1a; border-radius: 8px; border: 1px solid #333; }
        .download-title { margin-top: 0; color: #e5e5e5; font-size: 1.2rem; margin-bottom: 1rem; }
        .download-buttons { display: flex; gap: 1rem; flex-wrap: wrap; }
        
        .btn-download { background-color: #333; color: white; padding: 0.8rem 1.5rem; text-decoration: none; border-radius: 4px; font-weight: bold; transition: 0.2s; border: 1px solid #555; display: inline-flex; align-items: center; }
        .btn-download:hover { background-color: #e50914; border-color: #e50914; }
        
        .btn-download-sub { background-color: transparent; color: #aaa; padding: 0.8rem 1.5rem; text-decoration: none; border-radius: 4px; font-weight: bold; transition: 0.2s; border: 1px solid #555; display: inline-flex; align-items: center; }
        .btn-download-sub:hover { color: white; border-color: white; }
    </style>
</head>
<body>

    <div class="navbar">
        <h2>KVALIM</h2>
        <div class="nav-links">
            <% if (user.role === 'admin') { %>
                <a href="/dashboard">Admin Dashboard</a>
            <% } %>
            <a href="/gallery">Gallery</a>
            <a href="/logout">Logout (<%= user.username %>)</a>
        </div>
    </div>

    <div class="player-container">
        <a href="/gallery" class="back-btn">← Back to Gallery</a>
        
        <div class="video-wrapper">
            <video controls autoplay controlsList="nodownload">
                <source src="/play/<%= video.video_path %>" type="video/mp4">
                <% if (video.subtitle_path) { %>
                    <track label="עברית" kind="subtitles" srclang="he" src="/uploads/subtitles/<%= video.subtitle_path %>" default>
                <% } %>
                Your browser does not support the video tag.
            </video>
        </div>
        <div class="download-section">
            <h3 class="download-title">Download Options</h3>
            <div class="download-buttons">
                <a href="/uploads/videos/<%= video.video_path %>" download="<%= video.title %>.mp4" class="btn-download">
                    ⬇️ Download Video
                </a>
                
                <% if (video.subtitle_path) { %>
                    <a href="/uploads/subtitles/<%= video.subtitle_path %>" download="<%= video.title %>.vtt" class="btn-download-sub">
                        📝 Download Subtitles
                    </a>
                <% } %>
            </div>
            <p style="font-size: 0.85rem; color: #888; margin-bottom: 0; margin-top: 1rem;">
                <em>Tip: If watching offline with VLC Player, put both files in the same folder and give them the exact same name to load subtitles automatically.</em>
            </p>
        </div>

        <div class="video-info">
            <h1 class="video-title"><%= video.title %></h1>
            <% if (video.series_name) { %>
                <p class="series-context"><strong><%= video.series_name %></strong> | Season <%= video.season_number %>, Episode <%= video.episode_number %></p>
            <% } %>
            <p class="upload-date">Uploaded on <%= new Date(video.upload_date).toLocaleDateString() %></p>
        </div>

        <div class="video-info" style="margin-top: 2rem;">
            <h3>Comments</h3>
            
            <form action="/watch/<%= video.id %>/comment" method="POST" style="margin-bottom: 2rem;">
                <textarea name="comment_text" required placeholder="Write a comment..." 
                        style="width: 100%; height: 80px; background: #141414; color: #fff; border: 1px solid #333; padding: 10px; border-radius: 5px; 
                                font-family: 'Segoe UI', 'Heebo', sans-serif; font-size: 1rem; line-height: 1.5;"></textarea>
                <button type="submit" class="btn" style="margin-top: 0.5rem; background: #e50914; border: none; padding: 0.5rem 1rem; color: #fff; border-radius: 5px; cursor: pointer;">Post Comment</button>
            </form>

            <% comments.forEach(comment => { %>
                <div style="background: #141414; padding: 1rem; border-radius: 5px; margin-bottom: 1rem; position: relative;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div>
                            <div style="font-weight: bold; color: #4a90e2;"><%= comment.username %></div>
                            <div style="margin-top: 0.5rem; font-family: 'Segoe UI', 'Heebo', sans-serif;"><%= comment.comment_text %></div>
                        </div>

                        <% if (user.userId === comment.user_id || user.role === 'admin') { %>
                            <form action="/watch/<%= video.id %>/comment/<%= comment.id %>/delete" method="POST" onsubmit="return confirm('Delete this comment?');">
                                <button type="submit" style="background: none; border: none; color: #666; cursor: pointer; font-size: 0.8rem;">Delete</button>
                            </form>
                        <% } %>
                    </div>
                    <div style="font-size: 0.7rem; color: #666; margin-top: 0.5rem;"><%= new Date(comment.timestamp).toLocaleString() %></div>
                </div>
            <% }) %>
        </div>

    </div>

</body>
</html>