<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Media Share</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { margin: 0; background-color: #141414; color: white; display: block; font-family: 'Segoe UI', 'Heebo', sans-serif; }
        .navbar { display: flex; justify-content: space-between; align-items: center; padding: 1.5rem 4%; background: #000; }
        .navbar h2 { margin: 0; color: #e50914; }
        .nav-links a { color: white; text-decoration: none; margin-left: 1.5rem; font-weight: bold; }
        
        .dashboard-container { max-width: 900px; margin: 4rem auto; padding: 2rem; background: #1e1e1e; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .form-group { margin-bottom: 1.5rem; }
        .form-group label { display: block; margin-bottom: 0.5rem; font-weight: bold; color: #ccc; }
        .form-group input[type="text"], .form-group input[type="number"] { width: 100%; padding: 0.8rem; background: #2b2b2b; border: 1px solid #444; color: white; border-radius: 4px; box-sizing: border-box; }
        .form-group input[type="file"] { width: 100%; padding: 0.5rem; background: #2b2b2b; color: white; border: 1px solid #444; border-radius: 4px; }
        .form-row { display: flex; gap: 1rem; }
        .form-row .form-group { flex: 1; }
        .btn-submit { background-color: #e50914; color: white; border: none; padding: 1rem 2rem; font-size: 1.1rem; border-radius: 4px; cursor: pointer; width: 100%; font-weight: bold; }
        .btn-submit:hover { background-color: #f40612; }
        .help-text { font-size: 0.8rem; color: #888; margin-top: 0.3rem; display: block; }

        /* Restored Table Styles */
        .table-section { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid #333; }
        .media-table { width: 100%; border-collapse: collapse; margin-top: 1rem; background: #1a1a1a; border-radius: 8px; overflow: hidden; }
        .media-table th, .media-table td { padding: 1rem; text-align: left; border-bottom: 1px solid #333; }
        .media-table th { background-color: #000; color: #e50914; font-weight: bold; }
        .media-table tr:hover { background-color: #222; }
        .btn-delete { background-color: transparent; color: #aaa; border: 1px solid #aaa; padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer; transition: 0.2s; }
        .btn-delete:hover { background-color: #e50914; color: white; border-color: #e50914; }
        
        /* NEW: Feature Button Styles */
        .btn-feature { background-color: #333; color: white; border: 1px solid #555; padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer; transition: 0.2s; font-size: 0.85rem; }
        .btn-feature:hover { background-color: #e50914; border-color: #e50914; }
        .badge-featured { color: #e50914; font-weight: bold; padding: 0.4rem 0; display: inline-block; }
    </style>
</head>
<body>

    <div class="navbar">
        <h2>MEDIA SHARE</h2>
        <div class="nav-links">
            <a href="/gallery">Gallery</a>
            <a href="/logout">Logout</a>
        </div>
    </div>

    <div class="dashboard-container">
        <h1 style="margin-top: 0; border-bottom: 1px solid #333; padding-bottom: 1rem;">Upload Media</h1>
        
        <form action="/dashboard/upload" method="POST" enctype="multipart/form-data">
            
            <div class="form-group">
                <label for="title">Title (Movie Name or Episode Title)</label>
                <input type="text" id="title" name="title" required placeholder="e.g., The Hedge Knight">
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="series_name">Series Name (Optional)</label>
                    <input type="text" id="series_name" name="series_name" placeholder="e.g., A Knight of the Seven Kingdoms">
                </div>
                <div class="form-group">
                    <label for="season_number">Season #</label>
                    <input type="number" id="season_number" name="season_number" min="1">
                </div>
                <div class="form-group">
                    <label for="episode_number">Episode #</label>
                    <input type="number" id="episode_number" name="episode_number" min="1">
                </div>
            </div>

            <div class="form-group" style="background: #2b2b2b; padding: 1rem; border-radius: 4px; border: 1px solid #444;">
                <label>Media Files</label>
                <div style="margin-bottom: 1rem;">
                    <label for="video" style="font-size: 0.9rem;">Video File (.mp4, .webm) *Required</label>
                    <input type="file" id="video" name="video" accept="video/mp4, video/webm" required>
                </div>
                <div>
                    <label for="subtitle" style="font-size: 0.9rem;">Subtitles (.vtt) *Optional</label>
                    <input type="file" id="subtitle" name="subtitle" accept=".vtt">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group" style="background: #2b2b2b; padding: 1rem; border-radius: 4px; border: 1px solid #444;">
                    <label for="thumbnail">Episode Thumbnail</label>
                    <span class="help-text">Horizontal 16:9 ratio. Displays in the player and episode lists.</span>
                    <input type="file" id="thumbnail" name="thumbnail" accept="image/*" style="margin-top: 0.5rem;">
                </div>
                
                <div class="form-group" style="background: #222; padding: 1rem; border-radius: 4px; border: 1px solid #e50914;">
                    <label for="series_poster" style="color: #e50914;">Series Poster</label>
                    <span class="help-text">Vertical 4:5 ratio (IMDB style). <b>Only needed on Episode 1.</b></span>
                    <input type="file" id="series_poster" name="series_poster" accept="image/*" style="margin-top: 0.5rem;">
                </div>
            </div>

            <div class="form-group" style="display: flex; align-items: center; gap: 10px; margin-top: 1rem;">
                <input type="checkbox" id="is_recommended" name="is_recommended" style="width: 20px; height: 20px;">
                <label for="is_recommended" style="margin: 0;">Set as Admin's Pick (Featured on Homepage)</label>
            </div>

            <button type="submit" class="btn-submit">Upload to Server</button>
        </form>

        <div class="table-section">
            <h2 style="margin: 0 0 1rem 0;">Manage Uploaded Media</h2>
            
            <% if (typeof videos !== 'undefined' && videos.length > 0) { %>
                <table class="media-table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Series</th>
                            <th>Season / Ep</th>
                            <th>Featured</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% videos.forEach(video => { %>
                            <tr>
                                <td style="font-weight: bold;"><%= video.title %></td>
                                <td><%= video.series_name ? video.series_name : 'Standalone Movie' %></td>
                                <td>
                                    <% if (video.series_name) { %>
                                        S<%= video.season_number %>:E<%= video.episode_number %>
                                    <% } else { %>
                                        --
                                    <% } %>
                                </td>
                                <td>
                                    <% if (video.is_recommended) { %>
                                        <span class="badge-featured">⭐ Active Pick</span>
                                    <% } else { %>
                                        <form action="/dashboard/recommend/<%= video.id %>" method="POST" style="margin: 0;">
                                            <button type="submit" class="btn-feature">Set as Pick</button>
                                        </form>
                                    <% } %>
                                </td>
                                <td>
                                    <form action="/dashboard/delete/<%= video.id %>" method="POST" onsubmit="return confirm('Are you sure you want to completely delete this video?');" style="margin: 0;">
                                        <button type="submit" class="btn-delete">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <div style="background: #1a1a1a; padding: 2rem; text-align: center; border-radius: 8px; color: #888;">
                    <p>No media uploaded yet. Use the form above to add your first video.</p>
                </div>
            <% } %>
        </div>

    </div>

</body>
</html>